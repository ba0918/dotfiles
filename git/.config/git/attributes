# ============================================================
# Global gitattributes — すべての repo に適用される
# XDG: ~/.config/git/attributes （git が自動検出）
# ============================================================

# ===== デフォルト: テキスト判定は git に任せる、改行は正規化 =====
* text=auto

# ===== Shell / Scripts =====
*.sh       text eol=lf
*.bash     text eol=lf
*.zsh      text eol=lf
*.fish     text eol=lf
Makefile   text eol=lf
*.mk       text eol=lf

# ===== Windows 系スクリプトは CRLF 強制 =====
*.bat      text eol=crlf
*.cmd      text eol=crlf
*.ps1      text eol=crlf

# ===== git 組み込み diff ドライバ（関数ヘッダ検出が賢くなる） =====
*.c        text diff=cpp
*.h        text diff=cpp
*.cpp      text diff=cpp
*.hpp      text diff=cpp
*.cs       text diff=csharp
*.css      text diff=css
*.go       text diff=golang
*.html     text diff=html
*.htm      text diff=html
*.java     text diff=java
*.kt       text diff=kotlin
*.md       text diff=markdown
*.markdown text diff=markdown
*.pl       text diff=perl
*.pm       text diff=perl
*.php      text diff=php
*.py       text diff=python
*.rb       text diff=ruby
*.rs       text diff=rust
*.tex      text diff=tex

# ===== バイナリファイル（diff 抑制 + eol 無視） =====
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.webp     binary
*.ico      binary
*.icns     binary
*.svg      text
*.pdf      binary
*.zip      binary
*.7z       binary
*.tar      binary
*.tar.gz   binary
*.tgz      binary
*.gz       binary
*.bz2      binary
*.xz       binary
*.rar      binary
*.dmg      binary
*.iso      binary
*.mp3      binary
*.m4a      binary
*.wav      binary
*.flac     binary
*.mp4      binary
*.mov      binary
*.avi      binary
*.webm     binary
*.ttf      binary
*.otf      binary
*.woff     binary
*.woff2    binary
*.eot      binary
*.so       binary
*.dylib    binary
*.dll      binary
*.exe      binary
*.class    binary
*.jar      binary
*.pyc      binary
*.wasm     binary
*.sqlite   binary
*.sqlite3  binary
*.db       binary

# ===== ロックファイル: GitHub の linguist で「生成物」扱いにして差分表示を畳む =====
package-lock.json   linguist-generated
yarn.lock           linguist-generated
pnpm-lock.yaml      linguist-generated
Cargo.lock          linguist-generated -diff
poetry.lock         linguist-generated -diff
uv.lock             linguist-generated -diff
Gemfile.lock        linguist-generated -diff
composer.lock       linguist-generated -diff
bun.lockb           binary linguist-generated

# ===== GitHub linguist: ベンダー / 生成物を言語統計から除外 =====
vendor/**           linguist-vendored
third_party/**      linguist-vendored
*.min.js            linguist-generated
*.min.css           linguist-generated
*.map               linguist-generated
